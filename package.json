{
  "name": "linkx",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "homepage": "https://coleyrockin.github.io/linkx/",
  "scripts": {
    "dev": "vite",
    "start": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "lint": "eslint src --max-warnings 0",
    "og": "mkdir -p /tmp/og && qlmanage -t -s 1200 -o /tmp/og scripts/og.svg && sips -c 630 1200 /tmp/og/og.svg.png --out public/og-image.jpg -s format jpeg -s formatOptions 88",
    "screenshot": "node scripts/screenshot.mjs"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-icons": "^5.3.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/mocker": "^4.1.4",
    "eslint": "^9.17.0",
    "eslint-plugin-react": "^7.37.2",
    "eslint-plugin-react-hooks": "^5.1.0",
    "jsdom": "^25.0.1",
    "vite": "^6.0.7",
    "vitest": "^3.2.4"
  }
}
